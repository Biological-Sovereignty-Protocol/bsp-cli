  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@biological-sovereignty-protocol/sdk": "^2.1.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
