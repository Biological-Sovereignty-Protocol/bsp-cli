{
  "name": "@biological-sovereignty-protocol/cli",
  "version": "1.0.0",
  "description": "Official CLI for the Biological Sovereignty Protocol — manage BEOs, IEOs, consent, and health data from the terminal",
  "bin": {
    "bsp": "./dist/index.js"
  },
  "main": "dist/index.js",
